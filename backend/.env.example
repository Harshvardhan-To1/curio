# ─────────────────────────────────────────────────────────────────────────────
# SiteRAG backend configuration. Copy to `.env` and adjust.
# ─────────────────────────────────────────────────────────────────────────────

# --- Runtime ---
NODE_ENV=development
# Process role: `api` (HTTP only), `worker` (queue consumer only), or `all` (both).
# In docker-compose the `api` and `worker` services set this to api/worker.
ROLE=all
PORT=8000
LOG_LEVEL=debug
# Pretty-print logs in dev. Set false in prod for JSON logs.
LOG_PRETTY=true

# --- CORS: comma-separated list of allowed frontend origins (no trailing slash) ---
CORS_ORIGINS=http://localhost:3000

# --- Postgres ---
DATABASE_URL=postgres://siterag:siterag@localhost:5432/siterag
# Auto-create/update tables on boot. Use migrations in real prod; fine for dev.
DB_SYNCHRONIZE=true

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Embedding mode ---
# thin-server: ship cleaned chunks only; the browser embeds them.  (default)
# fat-server : the server precomputes embeddings with EMBED_MODEL.
EMBED_MODE=thin-server
# MUST match the browser's Transformers.js model id for retrieval parity.
EMBED_MODEL=Xenova/all-MiniLM-L6-v2
EMBED_DIM=384
# Store vectors in a pgvector column (requires the `vector` extension).
# If false, fat-server vectors are stored as JSON (works without the extension).
USE_PGVECTOR=false

# --- Crawler defaults (per-job options can override) ---
CRAWL_USER_AGENT=SiteRAGBot/0.1 (+https://siterag.app/bot)
CRAWL_MAX_PAGES=100
CRAWL_MAX_DEPTH=3
CRAWL_REQUESTS_PER_SECOND=2
CRAWL_PER_PAGE_TIMEOUT_MS=15000
CRAWL_TIME_BUDGET_MS=180000
CRAWL_MAX_CONTENT_BYTES=5000000
# Same-origin only by default; set false to allow subdomains of the seed host.
CRAWL_SAME_ORIGIN_ONLY=true
CRAWL_RESPECT_ROBOTS=true
CRAWL_WORKER_CONCURRENCY=2

# --- Chunking ---
CHUNK_TARGET_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# --- Security ---
# Block crawling private/loopback/link-local/metadata IP ranges (SSRF guard).
# Only disable for trusted local fixture testing.
SSRF_ALLOW_PRIVATE=false
# Per-IP API rate limit (requests per TTL window).
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=30

# --- Object storage (optional; raw HTML + corpus JSON). Leave blank to skip. ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# --- Observability ---
SENTRY_DSN=
