# Base URL of the SiteRAG backend (crawl + corpus API).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Default in-browser generation model (must be a valid @mlc-ai/web-llm model id).
NEXT_PUBLIC_DEFAULT_MODEL=Llama-3.2-1B-Instruct-q4f16_1-MLC

# Embedding model — MUST match the backend's EMBED_MODEL in fat-server mode.
NEXT_PUBLIC_EMBED_MODEL=Xenova/all-MiniLM-L6-v2
